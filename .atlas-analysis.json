  "keyFeatures": [
    "Natural language coding assistance directly in the terminal",
    "Full file system access — read, write, edit files with partial string replacement",
    "Shell command execution via BashTool with permission controls",
    "Git workflow automation — commits, PRs, code review",
    "Multi-agent orchestration with AgentTool and TeamCreateTool",
    "MCP (Model Context Protocol) server integration",
    "IDE bridge for VS Code and JetBrains",
    "Persistent memory and session management",
    "Skill system for reusable agentic workflows",
    "Plugin architecture for extending functionality",
    "Voice input support",
    "Vim mode"
  ],
  "publicApiSurface": [
    "BashTool — Shell command execution",
    "FileReadTool — Read files including images, PDFs, Jupyter notebooks",
    "FileWriteTool — Create or overwrite files",
    "FileEditTool — Partial file modification via string replacement",
    "GlobTool — File pattern matching",
    "GrepTool — ripgrep-based content search",
    "WebFetchTool — Fetch URL content",
    "WebSearchTool — Web search",
    "AgentTool — Sub-agent spawning",
    "SkillTool — Execute reusable skill workflows",
    "MCPTool — MCP server tool invocation",
    "TaskCreateTool / TaskUpdateTool — Task lifecycle management",
    "TeamCreateTool / TeamDeleteTool — Team agent management",
    "EnterPlanModeTool / ExitPlanModeTool — Plan mode toggle",
    "/commit — Create a git commit",
    "/review — Code review",
    "/mcp — MCP server management",
    "/config — Settings management",
    "/doctor — Environment diagnostics",
